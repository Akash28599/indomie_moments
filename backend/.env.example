# ═══════════════════════════════════════════════════════════
# INDOMIE MOMENTS — BACKEND (.env)
# ═══════════════════════════════════════════════════════════

# ── Server ──
PORT=8080
NODE_ENV=production
TIMEZONE=Africa/Lagos

# ── Database (PostgreSQL) ──
# Option A: Full connection string (recommended)
DB_CONNECTION_STRING=postgresql://user:password@host:5432/indomie_db?sslmode=require
# Option B: Individual variables (used if DB_CONNECTION_STRING is not set)
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=indomie
# DB_CONNECT_SSL_REQUIRED=true

# ── JWT Secrets (REQUIRED — change these!) ──
JWT_ADMIN_SECRET=CHANGE_ME_min_32_chars_random_string_for_admin
JWT_CONSUMER_SECRET=CHANGE_ME_min_32_chars_random_string_for_consumer
JWT_USER_SECRET=CHANGE_ME_min_32_chars_random_string_for_user
# JWT_ADMIN_REFRESH_SECRET=optional_separate_refresh_secret
# JWT_CONSUMER_REFRESH_SECRET=optional_separate_refresh_secret

# ── URLs ──
FRONTEND_URL=https://your-domain.com/indomie-moments
BACKEND_URL=https://your-domain.com

# ── Azure Blob Storage (for image uploads) ──
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account
AZURE_STORAGE_ACCOUNT_KEY=your_storage_key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=tgimcontainer

# ── SMS Provider: Bigture (Primary) ──
BIGTURE_API_KEY=your_bigture_api_key
BIGTURE_SYSTEM_ID=trans

# ── SMS Provider: Termii (Fallback) ──
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=N-Alert

# ── OTP Test Mode ──
# Set to true only in development/staging
OTP_TEST_MODE=false

# ── Social Login (Google) ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# ── Social Login (Facebook) ──
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://your-domain.com/api/auth/facebook/callback

# ── SMTP (for admin password reset emails) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@indomie.com

# ── External API Token (optional) ──
# API_TOKEN=your_api_token

# ── Promo Start Date ──
# PROMO_START_DATE=2026-01-01
