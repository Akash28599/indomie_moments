# ═══════════════════════════════════════════════════════════
# INDOMIE MOMENTS — FRONTEND (.env)
# ═══════════════════════════════════════════════════════════

# App Name
VITE_APP_NAME=INDOMIE
VITE_APP_TIMEZONE=Africa/Lagos

# ── BASE PATH ──
# Set this to the subdirectory path where the frontend is deployed.
# Example: /indomie-moments/  (MUST end with /)
# Leave as / if deployed at root domain.
VITE_BASE_PATH=/indomie-moments/

# ── API URL ──
# The backend API base URL (must end with /api, no trailing slash)
# Local:      http://localhost:8080/api
# Production: https://your-domain.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# ── Environment ──
NODE_ENV=production

# ── OTP Test Mode ──
# Set to true only in development/staging for bypass OTP
VITE_OTP_TEST_MODE=false
# VITE_OTP_TEST_PHONE=2347012345345
# VITE_OTP_TEST_CODE=123456

# ── Feature Flags ──
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_LOG_LEVEL=info

# ── Auth Mode ──
VITE_AUTH_MODE=cookie
